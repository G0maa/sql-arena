# Postgres connection string used by the app (Kysely/pg).
# For local `npm run start:dev` against the compose Postgres, use localhost.
# Inside docker compose the app uses the service hostname (see docker-compose.yml).
DATABASE_URL=postgres://arena:arena@localhost:5432/sql_arena

# HTTP port the NestJS app listens on.
PORT=3000

# Host port Docker Compose publishes Postgres on. Override if 5432 is already
# in use on your machine (e.g. POSTGRES_PORT=5433). Only affects the host
# mapping — the app always reaches Postgres on 5432 over the compose network.
POSTGRES_PORT=5432

# Role-scoped connection strings used by the submission runner (AgDR-0009).
# arena_runner — executes contestant SQL in isolation on the `seed` schema.
# arena_rw     — reads questions and writes submissions/leaderboard in `app`.
RUNNER_DATABASE_URL=postgres://arena_runner:runner@localhost:5432/sql_arena
RW_DATABASE_URL=postgres://arena_rw:rw@localhost:5432/sql_arena

# Passwords for the two database roles created by db/00-bootstrap.sh:
#   arena_runner — runs contestant SQL on the `seed` schema (owns those tables,
#                  so contestants can CREATE INDEX); cannot reach `app`.
#   arena_rw     — read/write on the `app` schema (questions / queue / board);
#                  cannot reach `seed`.
# These dev defaults match docker-compose.yml. Set real values in production.
ARENA_RUNNER_PASSWORD=runner
ARENA_RW_PASSWORD=rw

# --- Seed generator scale knobs (db:seed:generate) -------------------------
# Defaults are FULL target scale (~3M order_details) — lower them for a quick
# local correctness check, e.g. SEED_PRODUCTS=500 SEED_ORDERS=1000 npm run db:seed.
# SEED_RANDOM fixes the faker seed so a given knob set reproduces identical CSVs.
# SEED_CATEGORIES=100
# SEED_CUSTOMERS=1000000
# SEED_PRODUCTS=100000
# SEED_ORDERS=1000000
# SEED_MAX_DETAILS=5
# SEED_RANDOM=42

# Where the loader (db:seed:load) reads CSVs FROM, as seen by the Postgres
# server (server-side COPY). Defaults to the compose mount path; only override
# if you run Postgres outside the provided docker-compose.
# SEED_DATA_DIR=/seed-data
