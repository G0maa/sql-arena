# Production environment for docker-compose.prod.yml — copy to `.env` on the
# server and fill with REAL secrets. `.env` is gitignored; never commit it.
# Generate strong values, e.g.:  openssl rand -base64 24
#
# These three passwords are consumed by db/00-bootstrap.sh during the Postgres
# initdb on a fresh volume, and woven into the app's connection strings by
# docker-compose.prod.yml. There are no dev fallbacks in production.

# Superuser / owner role (POSTGRES_PASSWORD) — also used by the seed loaders.
POSTGRES_PASSWORD=

# arena_runner — executes contestant SQL in isolation on the `seed` schema.
ARENA_RUNNER_PASSWORD=

# arena_rw — reads questions / writes submissions + leaderboard in `app`.
ARENA_RW_PASSWORD=

# --- Seed scale (db:seed:generate) -----------------------------------------
# Defaults are FULL target scale already (100 categories / 1,000,000 customers /
# 100,000 products / 1,000,000 orders → ~3M order_details), so you normally set
# nothing here on the server. Listed for reference / to dial down for a quick
# check. SEED_RANDOM fixes faker so a given knob set reproduces identical CSVs.
# SEED_CATEGORIES=100
# SEED_CUSTOMERS=1000000
# SEED_PRODUCTS=100000
# SEED_ORDERS=1000000
# SEED_MAX_DETAILS=5
# SEED_RANDOM=42
