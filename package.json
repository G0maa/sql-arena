{
  "name": "sql-arena",
  "version": "0.0.1",
  "description": "SQL-optimization solution-runner + execution-time leaderboard",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:bootstrap": "./db/00-bootstrap.sh",
    "db:seed:generate": "tsx src/seed/generate.ts",
    "db:seed:load": "tsx src/seed/load.ts",
    "db:seed": "npm run db:seed:generate && npm run db:seed:load",
    "db:questions": "tsx src/seed/load-questions.ts",
    "test": "node --require tsx/cjs --test $(find src -name '*.spec.ts' | grep -v '\\.int\\.spec\\.ts')",
    "test:cov": "node --require tsx/cjs --experimental-test-coverage --test $(find src -name '*.spec.ts' | grep -v '\\.int\\.spec\\.ts')",
    "test:int": "node --require tsx/cjs --test $(find src -name '*.spec.ts')"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/serve-static": "^4.0.2",
    "kysely": "^0.27.4",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.4",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/sinon": "^21.0.1",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "expect": "^30.4.1",
    "prettier": "^3.3.0",
    "sinon": "^22.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0"
  }
}
